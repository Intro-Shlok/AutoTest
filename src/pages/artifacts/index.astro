---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const tools = await getCollection("tools");

interface ArtifactEntry {
  id: string;
  name: string;
  namespace: string;
  produces: boolean;
  consumes: boolean;
}

const base = import.meta.env.BASE_URL;
const artMap: Record<string, ArtifactEntry[]> = {};

for (const tool of tools) {
  const data = tool.data;
  const ns = data.namespace;
  const entryBase = { id: data.id, name: data.name, namespace: ns };

  // workflow_edges.produces / consumes
  const edges = data.workflow_edges || {};
  for (const art of edges.produces || []) {
    if (!artMap[art]) artMap[art] = [];
    artMap[art].push({ ...entryBase, produces: true, consumes: false });
  }
  for (const art of edges.consumes || []) {
    if (!artMap[art]) artMap[art] = [];
    // Check if already added as producer for this artifact
    const existing = artMap[art].find((e) => e.id === data.id);
    if (existing) {
      existing.consumes = true;
    } else {
      artMap[art].push({ ...entryBase, produces: false, consumes: true });
    }
  }

  // contract.inputs / outputs
  const contract = data.contract || {};
  for (const inp of contract.inputs || []) {
    const art = inp.type;
    if (!art) continue;
    if (!artMap[art]) artMap[art] = [];
    const existing = artMap[art].find((e) => e.id === data.id);
    if (existing) {
      existing.consumes = true;
    } else {
      artMap[art].push({ ...entryBase, produces: false, consumes: true });
    }
  }
  for (const out of contract.outputs || []) {
    const art = out.type;
    if (!art) continue;
    if (!artMap[art]) artMap[art] = [];
    const existing = artMap[art].find((e) => e.id === data.id);
    if (existing) {
      existing.produces = true;
    } else {
      artMap[art].push({ ...entryBase, produces: true, consumes: false });
    }
  }
}

const sortedArts = Object.keys(artMap).sort();

const totalTools = tools.length;
const totalUnique = sortedArts.length;
---

<BaseLayout title="Artifacts" description="Complete index of artifact types produced and consumed across all tools">
  <section class="hero" style="padding: 2rem 0 1.5rem;">
    <h1 style="font-size: 2.2rem;">Artifacts</h1>
    <p>{totalUnique} unique artifact types across {totalTools} tools</p>
  </section>

  <div class="card-grid cols-2">
    {sortedArts.map((art) => {
      const entries = artMap[art];
      const producerCount = entries.filter((e) => e.produces).length;
      const consumerCount = entries.filter((e) => e.consumes).length;
      return (
        <div class="card" style="animation:none;">
          <div class="card-meta" style="margin-top:0;">
            <span class="tag" style="border-color:var(--green);color:var(--green);">{producerCount} producer{producerCount !== 1 ? "s" : ""}</span>
            <span class="tag" style="border-color:var(--amber);color:var(--amber);">{consumerCount} consumer{consumerCount !== 1 ? "s" : ""}</span>
          </div>
          <div class="card-title" style="font-size:0.95rem;margin-top:0.5rem;font-family:var(--font-mono);">
            <code style="font-size:0.9rem;">{art}</code>
          </div>
          <div class="card-desc" style="margin-top:0.6rem;">
            {entries.map((e) => (
              <a href={`${base}tools/${e.id}`} style="display:inline-block;margin:0.15rem 0.2rem;">
                {e.produces && e.consumes ? (
                  <span class="tag" style="border-color:var(--purple);color:var(--purple);font-size:0.7rem;">{e.name} ↔</span>
                ) : e.produces ? (
                  <span class="tag" style="border-color:var(--green);color:var(--green);font-size:0.7rem;">{e.name} →</span>
                ) : (
                  <span class="tag" style="border-color:var(--amber);color:var(--amber);font-size:0.7rem;">{e.name} ←</span>
                )}
              </a>
            ))}
          </div>
        </div>
      );
    })}
  </div>

  {sortedArts.length === 0 && (
    <p style="text-align:center;color:var(--text-muted);padding:3rem 0;">No artifacts found.</p>
  )}
</BaseLayout>
