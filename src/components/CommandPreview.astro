---
export interface Props {
  template: string;
  parameters?: Array<{ name: string; type?: string; required?: boolean; default_value?: any; description?: string; template_key?: string }>;
  globalVars?: Record<string, string>;
}

const { template, parameters = [], globalVars = {} } = Astro.props;

// Build a map of all known placeholders: name -> { parameter info, is_global }
const paramMap = new Map<string, { info: any; isGlobal: boolean; globalKey?: string }>();
for (const p of parameters) {
  const keys = [p.name];
  if (p.template_key && p.template_key !== p.name) keys.push(p.template_key);
  for (const k of keys) {
    paramMap.set(k, { info: p, isGlobal: false });
  }
}
for (const [placeholder, globalKey] of Object.entries(globalVars)) {
  if (paramMap.has(placeholder)) {
    paramMap.get(placeholder)!.isGlobal = true;
    paramMap.get(placeholder)!.globalKey = globalKey;
  } else {
    paramMap.set(placeholder, { info: { name: placeholder }, isGlobal: true, globalKey });
  }
}

// Extract unique placeholders from template
const placeholderRe = /\{([^}]+)\}/g;
const seenInTemplate = new Set<string>();
let m;
while ((m = placeholderRe.exec(template)) !== null) {
  seenInTemplate.add(m[1]);
}

const templatePlaceholders = Array.from(seenInTemplate).map((name) => ({
  name,
  meta: paramMap.get(name),
}));

// Collapse global vars + template into JSON for client-side JS
const previewJson = JSON.stringify({
  template,
  globalVars,
  paramNames: templatePlaceholders.map((p) => p.name),
});
---

<div class="cmd-preview cosmos-preview" data-preview={previewJson}>
  <div class="cmd-preview-header">
    <span class="cmd-preview-label">&#128203; Live Preview</span>
    <button class="cmd-preview-copy" onclick="copyPreviewCommand(this)" title="Copy command">&#128203; Copy</button>
  </div>
  <pre class="cmd-preview-output" id="cmd-preview-output"><code>{template}</code></pre>
  <div class="cmd-preview-params" id="cmd-preview-params">
    {templatePlaceholders.map((ph) => (
      <span class="cmd-placeholder" data-ph={ph.name}>
        <code class={`ph-tag ${ph.meta?.isGlobal ? "ph-global" : "ph-local"}`}>
          {ph.meta?.isGlobal ? `🌍 ${ph.name} → ${ph.meta.globalKey}` : `📎 ${ph.name}`}
        </code>
      </span>
    ))}
  </div>
</div>

<script>
  function cosmosState() {
    var cs = window.Cosmos;
    if (!cs) return {};
    try { return cs.getAll(); } catch (_) { return {}; }
  }

  function substitute(template, cosmosVals, globalVars) {
    var result = template;
    // First substitute global vars from cosmos
    for (var key in globalVars) {
      if (globalVars.hasOwnProperty(key)) {
        var cosmosKey = globalVars[key];
        var val = cosmosVals[cosmosKey];
        if (val !== undefined && val !== null) {
          result = result.split("{" + key + "}").join(String(val));
        }
      }
    }
    return result;
  }

  function updatePreviews() {
    var previews = document.querySelectorAll(".cosmos-preview");
    if (!previews.length) return;
    var cosmosVals = cosmosState();

    previews.forEach(function (el) {
      var data;
      try { data = JSON.parse(el.getAttribute("data-preview")); } catch (_) { return; }
      if (!data) return;

      var output = el.querySelector("#cmd-preview-output code") || el.querySelector(".cmd-preview-output code");
      if (!output) return;

      var substituted = substitute(data.template, cosmosVals, data.globalVars || {});

      // Highlight placeholders that are not yet filled
      var display = substituted;
      var unfilled = substituted.match(/\{[^}]+\}/g);
      if (unfilled) {
        unfilled.forEach(function (ph) {
          display = display.split(ph).join('<mark class="ph-unset">' + ph + "</mark>");
        });
      }
      output.innerHTML = display;

      // Update param badges with current values
      var paramEls = el.querySelectorAll(".cmd-placeholder");
      paramEls.forEach(function (pEl) {
        var phName = pEl.getAttribute("data-ph");
        if (!phName) return;
        var globalVarKey = data.globalVars ? data.globalVars[phName] : null;
        if (globalVarKey && cosmosVals[globalVarKey] !== undefined) {
          var tag = pEl.querySelector(".ph-tag");
          if (tag) {
            tag.textContent = "\uD83C\uDF0D " + phName + " = " + cosmosVals[globalVarKey];
          }
        }
      });
    });
  }

  window.copyPreviewCommand = function (btn) {
    var output = btn.closest(".cmd-preview").querySelector(".cmd-preview-output code");
    if (!output) return;
    var text = output.textContent || output.innerText;
    navigator.clipboard.writeText(text).then(function () {
      btn.textContent = "\u2705 Copied!";
      setTimeout(function () { btn.innerHTML = "\uD83D\uDCCB Copy"; }, 2000);
    });
  };

  // Hook into Cosmos changes
  (function init() {
    if (window.Cosmos) {
      window.Cosmos.onChange(function () { updatePreviews(); });
    }
    // Initial render after a short delay for Cosmos to initialize
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", function () { setTimeout(updatePreviews, 50); });
    } else {
      setTimeout(updatePreviews, 50);
    }
  })();
</script>

<style>
  .cmd-preview {
    background: var(--bg-card, #1a1a2e);
    border: 1px solid var(--border, #2a2a4a);
    border-radius: var(--radius, 8px);
    margin-bottom: 1.5rem;
    overflow: hidden;
  }
  .cmd-preview-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 1rem;
    background: var(--bg-secondary, #16213e);
    border-bottom: 1px solid var(--border, #2a2a4a);
  }
  .cmd-preview-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted, #888);
  }
  .cmd-preview-copy {
    padding: 0.2rem 0.6rem;
    background: var(--accent, #64ffda);
    color: #000;
    border: none;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
  }
  .cmd-preview-copy:hover {
    opacity: 0.85;
  }
  .cmd-preview-output {
    margin: 0;
    padding: 1rem;
    background: var(--bg-tertiary, #0d1b2a);
    overflow-x: auto;
  }
  .cmd-preview-output code {
    font-family: var(--font-mono, monospace);
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--text-primary, #e0e0e0);
    white-space: pre-wrap;
    word-break: break-all;
  }
  .cmd-preview-params {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding: 0.5rem 1rem;
    border-top: 1px solid var(--border, #2a2a4a);
    background: var(--bg-secondary, #16213e);
  }
  .ph-tag {
    font-size: 0.65rem;
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
    font-family: var(--font-mono, monospace);
  }
  .ph-global {
    background: rgba(100, 255, 218, 0.15);
    color: var(--accent, #64ffda);
    border: 1px solid rgba(100, 255, 218, 0.3);
  }
  .ph-local {
    background: rgba(100, 150, 255, 0.15);
    color: #6496ff;
    border: 1px solid rgba(100, 150, 255, 0.3);
  }
  .ph-unset {
    background: rgba(255, 100, 100, 0.2);
    color: #ff6464;
    padding: 0.05rem 0.2rem;
    border-radius: 2px;
  }
</style>
